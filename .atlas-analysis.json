  "keyFeatures": [
    "Operations Dashboard with real-time KPIs",
    "Package intake, barcode scanning, and check-off sorting",
    "Shipment manifest management (Air, Sea, China freight)",
    "Pre-alert management for inbound packages",
    "Backroom fulfillment with live customer queue",
    "Point of Sale (POS) for in-person payment processing",
    "Invoice generation and billing management",
    "Transaction reporting and daily revenue tracking",
    "End-of-Day (EOD) report with print support",
    "Customer management with account balances and activity",
    "Daily Dispatch & Delivery routing with map view",
    "Campaign broadcast manager (email/SMS to customers)",
    "Configurable shipping rate tables",
    "Branch and warehouse location management",
    "Payment gateway integration (Stripe, WiPay, Fygaro)",
    "Role-based access control and user management",
    "Customizable notification/email templates",
    "Platform branding and customization settings"
  ],
